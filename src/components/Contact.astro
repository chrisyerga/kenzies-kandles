---
---
<section
  id="contact"
  class="py-24"
  style="background: linear-gradient(180deg, #0d0125 0%, #1a0533 100%); border-top: 1px solid rgba(196,181,253,0.08);"
>
  <div class="max-w-2xl mx-auto px-6">

    <div class="text-center mb-12">
      <p class="text-[0.7rem] font-extrabold tracking-[0.15em] uppercase mb-2" style="color:#c4b5fd;">✦ Say Hello ✦</p>
      <span class="font-script block leading-none" style="font-size:2.8rem; color:#e879f9; text-shadow:0 0 20px rgba(232,121,249,0.4);">Get in</span>
      <span class="font-black tracking-widest text-white block" style="font-size:2.8rem; margin-top:-0.4rem;">TOUCH</span>
      <p class="text-white/40 mt-3">Custom orders and questions always welcome 💌</p>
    </div>

    <div
      class="rounded-2xl p-8"
      style="background:rgba(255,255,255,0.04); border:1px solid rgba(196,181,253,0.15); backdrop-filter:blur(10px);"
    >
      <form id="contact-form" class="space-y-5">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold tracking-wide text-white/50 mb-2">Name</label>
            <input class="form-input" type="text" name="name" placeholder="Your name" required />
          </div>
          <div>
            <label class="block text-xs font-bold tracking-wide text-white/50 mb-2">Email</label>
            <input class="form-input" type="email" name="email" placeholder="you@email.com" required />
          </div>
        </div>
        <div>
          <label class="block text-xs font-bold tracking-wide text-white/50 mb-2">Message</label>
          <textarea
            class="form-input resize-none"
            name="message"
            rows="4"
            placeholder="Tell me what scents you're dreaming of..."
            required
          ></textarea>
        </div>
        <div id="contact-status" class="hidden rounded-xl px-4 py-3 text-sm font-semibold text-center"></div>
        <button
          type="submit"
          id="contact-submit"
          class="glow-btn w-full text-white font-bold py-4 rounded-full text-base"
        >
          Send Message 💜
        </button>
      </form>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('contact-status') as HTMLDivElement;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submit.disabled = true;
    submit.textContent = 'Sending…';
    status.className = 'hidden rounded-xl px-4 py-3 text-sm font-semibold text-center';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: (form.elements.namedItem('name') as HTMLInputElement).value,
          email: (form.elements.namedItem('email') as HTMLInputElement).value,
          message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
        }),
      });

      if (res.ok) {
        status.textContent = '✓ Message sent! I\'ll get back to you soon 💜';
        status.className = 'rounded-xl px-4 py-3 text-sm font-semibold text-center';
        status.style.cssText = 'background:rgba(110,231,183,0.1);color:#6ee7b7;border:1px solid rgba(110,231,183,0.2);';
        form.reset();
        submit.textContent = 'Send Message 💜';
        submit.disabled = false;
      } else {
        const body = await res.json().catch(() => ({}));
        throw new Error(body.error || 'Something went wrong.');
      }
    } catch (err: any) {
      status.textContent = `✗ ${err.message || 'Failed to send. Please try again.'}`;
      status.className = 'rounded-xl px-4 py-3 text-sm font-semibold text-center';
      status.style.cssText = 'background:rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.2);';
      submit.textContent = 'Send Message 💜';
      submit.disabled = false;
    }
  });
</script>
