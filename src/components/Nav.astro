---
import site from '../data/site.json';
---
<nav class="fixed top-0 inset-x-0 z-50" style="background: rgba(10,0,25,0.85); border-bottom: 1px solid rgba(196,181,253,0.1); backdrop-filter: blur(20px);">
  <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">

    <!-- Logo -->
    <a href="#" class="leading-none block">
      <div class="font-script text-[2.2rem] leading-none" style="color:#f0abfc; text-shadow: 0 0 18px rgba(240,171,252,0.45);">Kenzie's</div>
      <div class="text-[1.7rem] font-black tracking-widest text-white leading-none mt-[-0.3rem]">KANDLES</div>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex gap-8 text-sm font-bold" style="color: rgba(255,255,255,0.5);">
      <a href="#products" class="hover:text-white transition-colors">Shop</a>
      <a href="#about"    class="hover:text-white transition-colors">About</a>
      <a href="#contact"  class="hover:text-white transition-colors">Contact</a>
    </div>

    <!-- CTA -->
    <a href="#contact" class="glow-btn text-white text-sm font-bold px-6 py-2.5 rounded-full">
      Order Now ✨
    </a>
  </div>
</nav>
